# =====================================================
# Environment Variables - Copy this to .env and fill in your values
# =====================================================

# -----------------------------------------------------
# SERVER CONFIGURATION (for Render deployment)
# -----------------------------------------------------
PORT=3001
NODE_ENV=production
CLIENT_URL=https://your-app.vercel.app

# -----------------------------------------------------
# CLIENT CONFIGURATION (for Vercel deployment)
# -----------------------------------------------------
NEXT_PUBLIC_SERVER_URL=https://your-server.onrender.com

# -----------------------------------------------------
# DEPLOYMENT CONFIGURATION
# -----------------------------------------------------
# These are used in vercel.json and render.yaml
# Replace these placeholders with your actual URLs after deployment

# Vercel App URL (after first deploy, update this)
VERCEL_URL=https://your-app.vercel.app

# Render Server URL (after first deploy, update this)
RENDER_URL=https://your-server.onrender.com
